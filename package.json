{
  "name": "sainsbury-mobile-sample",
  "version": "1.0.0",
  "private": true,
  "description": "Sample grocery mobile API used to demo small vs large PR routing to Slack",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "test": "node --test test/*.test.js",
    "pr:small": "bash scripts/create-test-pr.sh small",
    "pr:large": "bash scripts/create-test-pr.sh large",
    "pr:both": "bash scripts/create-test-pr.sh both",
    "demo:prs": "bash scripts/create-test-pr.sh both"
  },
  "engines": {
    "node": ">=18"
  }
}
